        {
            "name": "OAuth2 (django-oauth-toolkit)",
            "item": [
                {
                    "name": "1. Список OAuth2 приложений",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/api/o/applications/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "o",
                                "applications",
                                ""
                            ]
                        }
                    }
                },
                {
                    "name": "2. Получить OAuth2 токен (Resource Owner Password)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "grant_type",
                                    "value": "password"
                                },
                                {
                                    "key": "username",
                                    "value": "{{username}}"
                                },
                                {
                                    "key": "password",
                                    "value": "{{password}}"
                                },
                                {
                                    "key": "client_id",
                                    "value": "{{oauth_client_id}}"
                                },
                                {
                                    "key": "client_secret",
                                    "value": "{{oauth_client_secret}}"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/o/token/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "o",
                                "token",
                                ""
                            ]
                        }
                    }
                },
                {
                    "name": "3. Использовать токен для API запроса",
                    "request": {
                        "auth": {
                            "type": "oauth2",
                            "oauth2": [
                                {
                                    "key": "accessToken",
                                    "value": "PASTE_TOKEN_FROM_STEP_2",
                                    "type": "string"
                                },
                                {
                                    "key": "tokenType",
                                    "value": "Bearer",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer PASTE_TOKEN_FROM_STEP_2"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/restaurants/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "restaurants",
                                ""
                            ]
                        }
                    }
                },
                {
                    "name": "4. Introspect токен (проверка валидности)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "token",
                                    "value": "PASTE_TOKEN_FROM_STEP_2"
                                },
                                {
                                    "key": "client_id",
                                    "value": "{{oauth_client_id}}"
                                },
                                {
                                    "key": "client_secret",
                                    "value": "{{oauth_client_secret}}"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/o/introspect/",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "o",
                                "introspect",
                                ""
                            ]
                        }
                    }
                }
            ]
