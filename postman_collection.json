{
    "info": {
        "name": "TimQWees - Доставка еды API",
        "description": "Коллекция запросов для тестирования API сервиса доставки еды TimQWees.\n\nПеременные:\n- base_url: http://localhost:8080 (базовый URL сервера)\n- username/password: testuser/testpass123 (администратор)\n- oauth_client_id/oauth_client_secret: получить через /admin/oauth2_provider/application/\n\nКак запустить:\n1. Запустите сервер: python manage.py runserver 0.0.0.0:8080\n2. Создайте тестовые данные: python manage.py create_sample_data\n3. Импортируйте эту коллекцию в Postman\n4. Запускайте запросы по порядку",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://127.0.0.1:8080",
            "type": "string"
        },
        {
            "key": "username",
            "value": "admin",
            "type": "string"
        },
        {
            "key": "password",
            "value": "admin",
            "type": "string"
        },
        {
            "key": "oauth_client_id",
            "value": "otgIm9mNQiM1H38wywwn9OvL3dmqUykiZwh7QM3d",
            "type": "string"
        },
        {
            "key": "oauth_client_secret",
            "value": "pbkdf2_sha256$870000$xNQw3t7W6uOt9fXmSsWtE3$qLsDufI9EPARQpweJyyK4GxhywOgGqkX+RT92dja0qM=",
            "type": "string"
        }
    ],
