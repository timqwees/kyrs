# ========================================
# TimQWees — Переменные окружения
# ========================================
# СКОПИРУЙТЕ этот файл как .env и заполните своими значениями
# cp .env.example .env

# Django
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production-12345
ALLOWED_HOSTS=*

# База данных (по умолчанию SQLite для разработки)
# Для PostgreSQL раскомментируйте:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=timqwees
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=db
# DB_PORT=5432

# Redis — брокер для Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# Sentry — мониторинг ошибок (оставьте пустым для dev, получите DSN на sentry.io)
SENTRY_DSN=

# Email — Mailhog (тестовый SMTP)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@timqwees.com

# OAuth2 — django-oauth-toolkit (создайте Application через /admin/oauth2_provider/application/)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
